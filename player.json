  "class_resources": {
    "rage": {
      "label": "Rage",
      "max": 2,
      "current": 2,
      "recharge": "Long Rest",
      "description": "+2 damage · BPS Resistance · Advantage on STR checks & saves · 1 minute"
    }
  },
  "features": [
    {
      "name": "Rage",
      "source": "Barbarian 1",
      "description": "Bonus action. +2 damage on STR attacks. Resistance to bludgeoning, piercing, and slashing damage. Advantage on STR checks and saves. Lasts 1 minute. 2 uses / long rest."
    },
    {
      "name": "Unarmored Defense",
      "source": "Barbarian 1",
      "description": "AC = 10 + DEX mod (+2) + CON mod (+2) = 14 while not wearing armor."
    },
    {
      "name": "Daunting Roar",
      "source": "Leonin",
      "description": "Bonus action. Each creature of your choice within 10 ft must succeed on a WIS save (DC 8 + Prof + CON mod = 12) or become frightened until the end of your next turn. 1 use / short rest."
    },
    {
      "name": "Darkvision",
      "source": "Leonin",
      "description": "See in dim light as if bright light, and in darkness as if dim light, within 60 feet."
    },
    {
      "name": "Wanderer",
      "source": "Outlander",
      "description": "Excellent memory for maps and geography. Can find food and fresh water for yourself and up to 5 companions per day in natural environments."
    },
    {
      "name": "Subclass — Zealot (Planned)",
      "source": "Barbarian 3",
      "description": "Rage is holy fury. Damage feels like divine judgment. Hard to kill — destiny-driven. Sekhmet doesn't rage because he is emotional. He rages because something sacred has been violated. The Zealot path treats survival itself as a divine mandate."
    }
  ],
  "proficiencies": {
    "armor": ["Light Armor", "Medium Armor", "Shields"],
    "weapons": ["Simple Weapons", "Martial Weapons"],
    "tools": [],
    "languages": ["Common", "Leonin"]
  },
  "traits": {
    "personality": "He watches over companions as if they were a litter of newborn cubs. He does not show it openly — but he positions himself between danger and the weak without thinking.",
    "ideal": "Glory is remembrance. To be remembered is to resist erasure. Every battle must mean something — his name must echo in story long after his bones bleach in the sand.",
    "bond": "He walks so the memory of the First Land does not die. The weight of a fallen pride lives in every step.",
    "flaw": "He is slow to trust outsiders. Respect must be earned in sweat and blood. You do not simply enter a pride by standing near it."
  },
  "equipment": {
    "currency": { "pp": 0, "gp": 10, "ep": 0, "sp": 0, "cp": 0 },
    "carried": [
      { "name": "Sun-Disc Club",              "quantity": 1, "description": "Greatclub — The Fist of the First Land" },
      { "name": "Explorer's Pack",             "quantity": 1, "description": "" },
      { "name": "Hunting Trap",               "quantity": 1, "description": "" },
      { "name": "First-Land Stone Fragment",  "quantity": 1, "description": "A petrified shard of his homeland" },
      { "name": "Traveler's Clothes",         "quantity": 1, "description": "" },
      { "name": "Gold Ceremonial Arm Cuff",   "quantity": 1, "description": "Marks victories of the First Land" },
      { "name": "Desert Drum",                "quantity": 1, "description": "" },
      { "name": "Belt Pouch",                 "quantity": 1, "description": "" }
    ]
  },
  "backstory": {
    "summary": "Before the Temporal Compression, his homeland breathed with mythic air. The horizon was wider. Spirits walked the surface of things. Then the world hardened. Matter thickened. What moved like wind became stone-bound. His pride faded — some into legend, some into the petrified ruins that scholars now mistake for ancient monuments. He held form. Not because he was strongest — but because his will refused to dissolve. He walks a world smaller than it should be, carrying the memory of everything that was lost when the mythic gave way to the physical."
  }
},
